{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "next-app/**",
      "server/**",
      "package.json",
      "package-lock.json"
    ],
    "buildCommand": "npm ci && npm --prefix next-app ci && npm run next:build"
  },
  "deploy": {
    "preDeployCommand": [
      "npm run migrate"
    ],
    "startCommand": "npm run next:start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
