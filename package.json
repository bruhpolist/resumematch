{
  "name": "resume-builder-unified",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.mjs",
    "next:dev": "npm --prefix next-app run dev",
    "next:build": "npm --prefix next-app run build",
    "next:start": "npm --prefix next-app run start",
    "migrate": "node server/migrate.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "build": "npm --prefix client run build",
    "start": "cross-env NODE_ENV=production node server/index.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "vite": "^7.3.0"
  }
}
